Options -Indexes
Options -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# /blog i /blog/ uvijek otvori stranicu blog.html, ne mapu (Facebook bot)
RewriteRule ^blog/?$ blog.html [L]

# Podstranice bloga – pusti samo ako NIJE direktorij (server ne traži u mapi)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)$ blog/$1 [L]

# Ostale glavne stranice
RewriteRule ^about/?$ about.html [L]
RewriteRule ^contact/?$ contact.html [L]
RewriteRule ^admin/?$ admin.html [L]
</IfModule>
