Options -Indexes -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# 1. /blog ili /blog/ – odmah daj blog.html, prije svega
RewriteRule ^blog/?$ blog.html [L]

# 2. Blog post (npr. blog/neki-post.html) – samo ako datoteka postoji na disku
RewriteCond %{DOCUMENT_ROOT}/blog/$1.html -f
RewriteRule ^blog/(.+)\.html$ blog/$1.html [L]

# 3. Univerzalni fallback – about, contact, admin (dodaj .html ako datoteka postoji)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
</IfModule>
