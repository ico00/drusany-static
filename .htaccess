# Isključi automatsko dodavanje slasha koji uzrokuje 403 na mapama
DirectorySlash Off
Options -Indexes -MultiViews

DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# 1. Ako je zahtjev točno za mapu /blog ili /blog/, silom pošalji na blog.html
RewriteRule ^blog/?$ /blog.html [L,R=301]

# 2. Blog post – provjeri postoji li .html datoteka, serviraj je (sprječava gledanje u /blog mapu)
RewriteCond %{DOCUMENT_ROOT}/blog/$1.html -f
RewriteRule ^blog/(.+)\.html$ blog/$1.html [L]

# 3. Fallback za sve ostalo (index, about, contact...)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
</IfModule>
